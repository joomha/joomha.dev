---
export interface Props {
  type: "BlogPosting" | "Person" | "WebSite";
  data: any;
}

const { type, data } = Astro.props;

let structuredData = {};

if (type === "BlogPosting") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: data.title,
    description: data.description,
    author: {
      "@type": "Person",
      name: data.author || "Ahmad Jumhadi",
      url: "https://joomha.dev/about",
    },
    datePublished: data.pubDatetime.toISOString(),
    dateModified: data.modDatetime?.toISOString() || data.pubDatetime.toISOString(),
    publisher: {
      "@type": "Person",
      name: "Ahmad Jumhadi",
      logo: {
        "@type": "ImageObject",
        url: "https://joomha.dev/avatar.png",
      },
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": data.url,
    },
    image: data.ogImage || "https://joomha.dev/avatar.png",
    articleSection: data.tags?.[0] || "Technology",
    keywords: data.tags?.join(", ") || "",
    wordCount: data.wordCount,
    timeRequired: data.readingTime,
  };
} else if (type === "Person") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Ahmad Jumhadi",
    url: "https://joomha.dev",
    image: "https://joomha.dev/avatar.png",
    sameAs: [
      "https://github.com/joomha",
      "https://x.com/joomha",
      "https://www.linkedin.com/in/joomha",
    ],
    jobTitle: "Developer",
    description:
      "Personal space of Ahmad Jumhadi (@joomha). Developer interested in Data Science, AI, and SEO.",
  };
} else if (type === "WebSite") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Joomha",
    url: "https://joomha.dev",
    description:
      "Personal space of Ahmad Jumhadi (@joomha). Developer interested in Data Science, AI, and SEO.",
    author: {
      "@type": "Person",
      name: "Ahmad Jumhadi",
    },
    potentialAction: {
      "@type": "SearchAction",
      target: "https://joomha.dev/search?q={search_term_string}",
      "query-input": "required name=search_term_string",
    },
  };
}
---

<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
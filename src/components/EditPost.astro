---
import type { CollectionEntry } from "astro:content";
import IconEdit from "@/assets/icons/IconEdit.svg";
import { SITE } from "@/config";

export interface Props {
  hideEditPost?: CollectionEntry<"blog">["data"]["hideEditPost"];
  class?: string;
  post: CollectionEntry<"blog">;
}

const { hideEditPost, post, class: className = "" } = Astro.props;

let path = post.filePath || "";
// Clean up path to be relative to the GitHub repo root
if (path.includes("src/content/")) {
  path = path.substring(path.indexOf("src/content/"));
} else if (path.includes("src\\content\\")) {
  path = path.substring(path.indexOf("src\\content\\")).replace(/\\/g, "/");
} else {
  // If filePath doesn't contain src/content (e.g. only contains the filename), fallback to using post.id
  path = `src/content/blog/${post.id}${post.id.match(/\.mdx?$/) ? '' : '.md'}`;
}

// Ensure the base URL is just the repo base
const repoBase = SITE.editPost.url.replace(/\/src\/content\/blog\/?$/, "");
const href = `${repoBase}/${path}`.replace(/([^:]\/)\/+/g, "$1"); // remove double slashes except after http://
const showEditPost = SITE.editPost.enabled && !hideEditPost && href.trim() !== "";
---

{
  showEditPost && (
    <div class:list={["opacity-80", className]}>
      <span aria-hidden="true" class="max-sm:hidden">
        |
      </span>
      <a
        class="space-x-1.5 hover:opacity-75"
        href={href}
        rel="noopener noreferrer"
        target="_blank"
      >
        <IconEdit class="inline-block size-6" />
        <span class="italic max-sm:text-sm sm:inline">
          {SITE.editPost.text}
        </span>
      </a>
    </div>
  )
}

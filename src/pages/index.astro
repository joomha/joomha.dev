---
import { getCollection } from "astro:content";
import Card from "@/components/Card.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import StructuredData from "@/components/StructuredData.astro";
import { SITE } from "@/config";
import Layout from "@/layouts/Layout.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { filterListingPosts } from "@/utils/getTranslationFilter";
import { HIGHLIGHTS } from "@/data/highlights";

const allPosts = await getCollection("blog");
const filteredPosts = filterListingPosts(allPosts);
const sortedPosts = getSortedPosts(filteredPosts);
const recentPosts = sortedPosts.slice(0, SITE.postPerIndex);

// Stats — auto-calculated (hanya menghitung artikel unik yang terpublikasi)
const totalPosts = filteredPosts.filter(p => !p.data.draft).length;
const totalProjects = filteredPosts.filter(p => p.data.tags.includes("portfolio") && !p.data.draft).length;
const totalVolunteer = filteredPosts.filter(p => p.data.tags.includes("volunteer") && !p.data.draft).length;
---

<Layout>
  <StructuredData type="WebSite" data={{}} />
  <StructuredData type="Person" data={{}} />
  <Header />
  <main id="main-content" data-layout="index">

    <!-- Instagram-style Profile Section -->
    <section class="pt-8 pb-6">
      <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6 sm:gap-10">
        <!-- Avatar -->
        <div class="relative group shrink-0">
          <div class="absolute -inset-1 bg-gradient-to-br from-accent/40 to-accent/10 rounded-full blur-md opacity-60 group-hover:opacity-100 transition-all duration-500"></div>
          <div class="relative w-24 h-24 sm:w-28 sm:h-28 bg-accent/10 rounded-full flex items-center justify-center border-2 border-accent/20">
            <span class="text-accent text-4xl sm:text-5xl font-bold">J</span>
          </div>
        </div>

        <!-- Profile Info -->
        <div class="flex flex-col items-center sm:items-start gap-3 flex-1">
          <div>
            <h1 class="text-xl sm:text-2xl font-bold tracking-tight">@joomha</h1>
            <p class="text-sm opacity-60 mt-0.5">Ahmad Jumhadi</p>
          </div>

          <!-- Stats Row -->
          <div class="flex gap-6 sm:gap-8">
            <a href="/posts" class="group text-center transition-all hover:-translate-y-0.5">
              <span class="block text-xl font-bold group-hover:text-accent transition-colors">{totalPosts}</span>
              <span class="text-xs opacity-50 uppercase tracking-wider">Posts</span>
            </a>
            <a href="/projects" class="group text-center transition-all hover:-translate-y-0.5">
              <span class="block text-xl font-bold group-hover:text-accent transition-colors">{totalProjects}</span>
              <span class="text-xs opacity-50 uppercase tracking-wider">Projects</span>
            </a>
            <div class="text-center">
              <span class="block text-xl font-bold">{totalVolunteer}</span>
              <span class="text-xs opacity-50 uppercase tracking-wider">Volunteer</span>
            </div>
          </div>

          <!-- Bio -->
          <p class="text-sm opacity-70 leading-relaxed max-w-md text-center sm:text-left">
            AI Enthusiast · Based in Indonesia<br/>
            Crafting simple, readable, and professional digital experiences.
          </p>
        </div>
      </div>
    </section>

    <!-- Story Highlights -->
    {HIGHLIGHTS.length > 0 && (
      <section class="pb-8">
        <div class="flex gap-5 overflow-x-auto pb-2 scrollbar-hide">
          {HIGHLIGHTS.map((hl) => (
            <div class="flex flex-col items-center gap-2 min-w-[80px] group">
              {/* Circle image */}
              <div class="relative">
                <div class="w-16 h-16 sm:w-[72px] sm:h-[72px] rounded-full p-[2px] bg-gradient-to-br from-accent/60 to-accent/20">
                  <div class="w-full h-full rounded-full overflow-hidden bg-background p-[2px]">
                    <img
                      src={hl.image}
                      alt={hl.title}
                      class="w-full h-full object-cover rounded-full"
                      loading="lazy"
                    />
                  </div>
                </div>
              </div>
              {/* Title */}
              <span class="text-[11px] font-medium text-center leading-tight opacity-70 max-w-[80px] truncate">
                {hl.title}
              </span>
              {/* Action buttons */}
              <div class="flex gap-1.5">
                {hl.postUrl && (
                  <a
                    href={hl.postUrl}
                    class="flex items-center justify-center w-6 h-6 rounded-full bg-muted/50 border border-border/50 hover:border-accent/50 hover:text-accent transition-all text-[10px]"
                    title={`Read about ${hl.title}`}
                    aria-label={`Read about ${hl.title}`}
                  >
                    📄
                  </a>
                )}
                {hl.actionUrl && (
                  <a
                    href={hl.actionUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center justify-center w-6 h-6 rounded-full bg-muted/50 border border-border/50 hover:border-accent/50 hover:text-accent transition-all text-[10px]"
                    title={hl.actionLabel || "Open link"}
                    aria-label={hl.actionLabel || "Open link"}
                  >
                    🔗
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Divider -->
    <hr class="border-border mb-8" />

    <!-- Latest Posts -->
    {recentPosts.length > 0 && (
      <section id="recent-posts" class="pb-16">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-xl font-semibold tracking-tight">Latest</h2>
          <span class="text-xs opacity-40 uppercase tracking-widest">{recentPosts.length} post{recentPosts.length > 1 ? 's' : ''}</span>
        </div>
        <ul class="space-y-1">
          {recentPosts.map((data) => (
            <Card variant="h3" {...data} showImage={false} />
          ))}
        </ul>
      </section>
    )}

  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>

---
import { getCollection } from "astro:content";
import Card from "@/components/Card.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import StructuredData from "@/components/StructuredData.astro";
import { SITE } from "@/config";
import Layout from "@/layouts/Layout.astro";
import getSortedPosts from "@/utils/getSortedPosts";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.slice(0, SITE.postPerIndex);
---

<Layout>
  <StructuredData type="WebSite" data={{}} />
  <StructuredData type="Person" data={{}} />
  <Header />
  <main id="main-content" data-layout="index">

    <!-- Hero: full-width asymmetric intro -->
    <section class="pt-16 pb-12">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
        <div class="lg:col-span-8">
          <p class="text-accent font-medium tracking-widest uppercase text-sm mb-3">Welcome</p>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-[1.1] mb-6">
            I'm <span class="text-accent">Joomha</span>,<br/>
            a AI Enthusiast.
          </h1>
          <p class="text-lg opacity-70 max-w-xl leading-relaxed">
            Crafting simple, readable, and professional digital experiences.
            This is my personal space to write, learn, and share.
          </p>
        </div>
        <div class="lg:col-span-4 flex justify-center lg:justify-end">
          <div class="relative group">
            <div class="absolute -inset-1 bg-gradient-to-br from-accent/30 to-accent/10 rounded-2xl blur-lg opacity-0 group-hover:opacity-100 transition-all duration-700"></div>
            <div class="relative bg-muted/50 border border-border rounded-2xl p-8 text-center">
              <div class="w-20 h-20 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="text-accent text-3xl font-bold">J</span>
              </div>
              <p class="text-sm font-medium">Based in Indonesia</p>
              <p class="text-xs opacity-50 mt-1">Have fun</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Bento-style grid: 3 info tiles -->
    <section class="pb-12">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="/about" class="group bg-muted/30 border border-border/50 rounded-2xl p-6 hover:border-accent/50 transition-all duration-300 hover:-translate-y-0.5">
          <div class="text-accent text-2xl mb-3">↗</div>
          <h3 class="font-semibold text-sm mb-1">About Me</h3>
          <p class="text-xs opacity-60">Learn more about what I do and my journey.</p>
        </a>
        <a href="/posts" class="group bg-muted/30 border border-border/50 rounded-2xl p-6 hover:border-accent/50 transition-all duration-300 hover:-translate-y-0.5">
          <div class="text-accent text-2xl mb-3">✦</div>
          <h3 class="font-semibold text-sm mb-1">All Posts</h3>
          <p class="text-xs opacity-60">Browse through all published writings.</p>
        </a>
        <a href="/projects" class="group bg-muted/30 border border-border/50 rounded-2xl p-6 hover:border-accent/50 transition-all duration-300 hover:-translate-y-0.5">
          <div class="text-accent text-2xl mb-3">⊞</div>
          <h3 class="font-semibold text-sm mb-1">Projects</h3>
          <p class="text-xs opacity-60">Selected works in AI, SEO, and Web Development.</p>
        </a>
      </div>
    </section>

    <!-- Latest Posts -->
    {recentPosts.length > 0 && (
      <section id="recent-posts" class="pb-16">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-xl font-semibold tracking-tight">Latest</h2>
          <span class="text-xs opacity-40 uppercase tracking-widest">{recentPosts.length} post{recentPosts.length > 1 ? 's' : ''}</span>
        </div>
        <ul class="space-y-1">
          {recentPosts.map((data) => (
            <Card variant="h3" {...data} showImage={false} />
          ))}
        </ul>
      </section>
    )}

  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
